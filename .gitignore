.DS_Store

# Ren'Py generated bytecode and caches
**/*.rpyc
**/cache/
**/__pycache__/
**/*.pyc

# Ren'Py local saves and player state
**/saves/
**/persistent
**/*.save

# Local runtime logs and crash outputs
**/log.txt
**/errors.txt
**/traceback.txt

# Test and coverage noise
.pytest_cache/
.coverage
htmlcov/

# macOS / editor noise
*.swp
*.swo
